{
  "name": "justdilo",
  "version": "1.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "gen:icons": "node scripts/gen-icons.mjs",
    "electron:compile": "tsc --project electron/tsconfig.json",
    "electron:dev": "npm run electron:compile && NODE_ENV=development electron .",
    "electron:build": "npm run electron:compile && electron-builder --mac --win",
    "electron:build:mac": "npm run electron:compile && electron-builder --mac",
    "electron:build:win": "npm run electron:compile && electron-builder --win",
    "gen:electron-icons": "node scripts/gen-electron-icons.mjs"
  },
  "build": {
    "appId": "app.justdilo",
    "productName": "JustDilo",
    "copyright": "Copyright © 2025 JustDilo",
    "icon": "build/icons/icon.png",
    "files": [
      "dist-electron/**/*",
      "build/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icons/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": null
  },
  "dependencies": {
    "@serwist/next": "^9.5.7",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "groq-sdk": "^0.7.0",
    "lucide-react": "^0.456.0",
    "msedge-tts": "^2.0.5",
    "next": "^15.3.1",
    "openai": "^4.71.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.53.2",
    "serwist": "^9.5.7",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5"
  }
}
