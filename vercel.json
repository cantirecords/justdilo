{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "app/api/process-voice/route.ts": {
      "maxDuration": 60
    },
    "app/api/meetings/finish/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    { "path": "/api/push/morning", "schedule": "0 13 * * *" },
    { "path": "/api/push/evening", "schedule": "0 2 * * *"  }
  ]
}
