{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "app/api/process-voice/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/push/morning",  "schedule": "0 11 * * *"  },
    { "path": "/api/push/evening",  "schedule": "0 2 * * *"   },
    { "path": "/api/push/reminder", "schedule": "*/5 * * * *" }
  ]
}
